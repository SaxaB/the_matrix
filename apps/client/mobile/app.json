{
  "expo": {
    "name": "Matrix",
    "slug": "the-matrix",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "thematrix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saxab.thematrix"
    },
    "android": {
      "package": "com.saxab.thematrix",
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Matrix usa el micrófono para que hables con saxa.",
          "speechRecognitionPermission": "Matrix transcribe tu voz para enviársela a saxa.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "extra": {}
  }
}

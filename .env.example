############
# the_matrix — plantilla de secrets (F0)
#
# cp .env.example .env  y CAMBIA TODOS los valores por defecto antes del
# primer arranque. Para generar JWT_SECRET + ANON_KEY + SERVICE_ROLE_KEY:
#   sh infra/supabase/generate-keys.sh
#
# .env NUNCA se commitea (está en .gitignore).
############

############
# Secrets
############

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Clave simétrica HS256 con la que GoTrue firma los JWT (mín. 32 chars)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
# JWTs firmados con JWT_SECRET (rol anon / service_role). Demo keys de
# Supabase: SOLO valen si no cambias JWT_SECRET. Regenerar con el script.
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# API keys opacas + JWK asimétricas (opcionales en F0; ver docs self-hosted-auth-keys)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Acceso a Studio (basic auth en Kong)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Usado por Realtime (64 chars aleatorios)
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Usado por Studio/postgres-meta (mín. 32 chars)
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

############
# URLs
############

# URL pública del API gateway (Kong). Con tunnel: https://api.<dominio>
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000

# URL del frontend (F2: web Next.js). Para los redirects de auth.
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

############
# Base de datos
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Auth (GoTrue)
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
# En F0 no hay SMTP real: autoconfirmar emails. Cambiar cuando haya SMTP.
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=the_matrix
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# Google OAuth (login por miembro, §4 del diseño)
GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=the_matrix
STUDIO_DEFAULT_PROJECT=the_matrix
# Opcional: habilita el asistente IA de Studio
OPENAI_API_KEY=

############
# API (PostgREST)
############

# Incluye los schemas por dominio de packages/db (market, finance, ...)
PGRST_DB_SCHEMAS=public,market,finance,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Web (apps/client/web)
############

# Cotizaciones en vivo (gratis en alphavantage.co; opcional, hay caché)
ALPHA_VANTAGE_API_KEY=
# Informes IA del perfil inversor y narrativa de riesgo (opcional)
ANTHROPIC_API_KEY=

############
# Agente saxa (apps/agent)
############

# Token del bot (BotFather). Long polling: no necesita URL pública.
TELEGRAM_BOT_TOKEN=
# Allowlist de chats (IDs separados por coma). VACÍA = el bot ignora todo.
TELEGRAM_ALLOWED_CHAT_IDS=
# Datos de mercado en vivo para tools (tier gratuito de finnhub.io)
FINNHUB_API_KEY=
# Fuentes sociales del briefing (opcionales; sin key => fuente omitida declarada)
# Pool Apify para lista X (coma-separado, fallback automático)
APIFY_KEYS=
# Pool Jina para búsqueda/lectura Citrini
JINA_KEYS=
# (ANTHROPIC_API_KEY ya declarada arriba la usan web y agente)

############
# ETL de mercado (apps/etl)
############

# User-Agent exigido por SEC EDGAR: identifícate con contacto real
SEC_EDGAR_USER_AGENT="the_matrix/0.1 (tu-email@example.com)"
# Zona horaria de calendarios/cadencias (n8n, earnings)
DASHBOARD_CALENDAR_TZ=Europe/Madrid
# Para correr jobs desde el host (fuera de Docker): URL del Kong local
# SUPABASE_URL=http://localhost:8000

############
# API gateway (Kong)
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Cloudflare Tunnel (perfil "tunnel"; requiere decisión #9: dominio)
############

# Token del tunnel creado en Zero Trust > Networks > Tunnels
TUNNEL_TOKEN=
